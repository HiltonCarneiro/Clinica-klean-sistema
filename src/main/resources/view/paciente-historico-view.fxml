<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.com.clinica.controller.PacienteHistoricoController"
            styleClass="page-clean"
            stylesheets="@/styles/app.css">

    <!-- ======= TOPO ======= -->
    <top>
        <VBox spacing="10" styleClass="top-clean">
            <padding>
                <Insets top="14" right="16" bottom="10" left="16"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Histórico do Paciente" styleClass="header-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Fechar" onAction="#onFechar" styleClass="btn-ghost"/>
            </HBox>

            <GridPane hgap="14" vgap="6" styleClass="info-grid">
                <columnConstraints>
                    <ColumnConstraints minWidth="110" halignment="RIGHT"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints minWidth="110" halignment="RIGHT"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Nome:" styleClass="label-muted" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblNome" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="CPF:" styleClass="label-muted" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <Label fx:id="lblCpf" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Telefone:" styleClass="label-muted" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblTelefone" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Data nasc.:" styleClass="label-muted" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <Label fx:id="lblDataNascimento" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Ativo:" styleClass="label-muted" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblAtivo" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <Separator/>
        </VBox>
    </top>

    <!-- ======= CENTRO: ABAS ======= -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="tabs-clean">

            <!-- ======================= ANEXOS ======================= -->
            <Tab text="Anexos / Exames">
                <VBox spacing="10" styleClass="tab-body">
                    <padding>
                        <Insets top="10" right="16" bottom="16" left="16"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Anexos do paciente" styleClass="section-title"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnAtualizarAnexos" text="Atualizar" onAction="#onAtualizarAnexos" styleClass="btn-ghost"/>
                        <Button fx:id="btnAbrirAnexo" text="Abrir" onAction="#onAbrirAnexo" disable="true" styleClass="btn-primary"/>
                    </HBox>

                    <TableView fx:id="tableAnexos" VBox.vgrow="ALWAYS" styleClass="table-soft">
                        <columns>
                            <TableColumn fx:id="colAnexoNome" text="Arquivo" prefWidth="320"/>
                            <TableColumn fx:id="colAnexoDescricao" text="Descrição" prefWidth="240"/>
                            <TableColumn fx:id="colAnexoDataHora" text="Data/Hora" prefWidth="160"/>
                        </columns>
                    </TableView>

                    <Label text="Dica: selecione um anexo e clique em “Abrir” para visualizar o PDF no leitor padrão."
                           styleClass="hint-text"/>
                </VBox>
            </Tab>

            <!-- ======================= ANAMNESE & EVOLUÇÕES ======================= -->
            <Tab text="Anamnese &amp; Evoluções">
                <BorderPane styleClass="tab-body">
                    <padding>
                        <Insets top="10" right="16" bottom="16" left="16"/>
                    </padding>

                    <top>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Histórico de Anamnese e Evoluções" styleClass="section-title"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnAtualizarAnamnese" text="Atualizar" onAction="#onAtualizarAnamnese" styleClass="btn-ghost"/>
                        </HBox>
                    </top>

                    <left>
                        <VBox spacing="8" prefWidth="360">
                            <TableView fx:id="tableAnamnese" VBox.vgrow="ALWAYS" styleClass="table-soft">
                                <columns>
                                    <TableColumn fx:id="colAnaDataHora" text="Data/Hora" prefWidth="170"/>
                                    <TableColumn fx:id="colAnaTipo" text="Tipo" prefWidth="160"/>
                                </columns>
                            </TableView>

                            <Label text="Selecione um item para ver os detalhes à direita."
                                   styleClass="hint-text"/>
                        </VBox>
                    </left>

                    <center>
                        <VBox spacing="10">
                            <Label text="Observações" styleClass="field-title"/>
                            <TextArea fx:id="txtObservacoes" prefRowCount="4" wrapText="true" editable="false" styleClass="area-clean"/>

                            <Label text="Resumo do registro" styleClass="field-title"/>
                            <TextArea fx:id="txtResumo" prefRowCount="14" wrapText="true" editable="false" styleClass="area-clean"/>

                            <TitledPane fx:id="tpJson" text="Dados técnicos (JSON)" expanded="false" styleClass="tp-clean">
                                <content>
                                    <TextArea fx:id="txtJson" prefRowCount="10" wrapText="false" editable="false" styleClass="area-clean mono"/>
                                </content>
                            </TitledPane>
                        </VBox>
                    </center>
                </BorderPane>
            </Tab>

        </TabPane>
    </center>

</BorderPane>